generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model activity_logs {
  id                     Int       @id @default(autoincrement())
  user_id                Int?
  action                 String    @db.VarChar(100)
  entity_type            String    @db.VarChar(50)
  entity_id              Int?
  details                Json?
  ip_address             String?   @db.VarChar(45)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  users                  users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_activity_logs_user")
}

model alerts {
  id                           Int           @id @default(autoincrement())
  type                         String        @db.VarChar(50)
  title                        String        @db.VarChar(255)
  message                      String
  field_id                     Int?
  customer_id                  Int?
  reservation_id               Int?
  user_id                      Int?
  status                       String?       @default("unread") @db.VarChar(20)
  priority                     String?       @default("medium") @db.VarChar(10)
  admin_id                     Int
  reservation_data             Json?
  user_id_registration         Int?
  date_time_registration       DateTime?     @default(now()) @db.Timestamptz(6)
  user_id_modification         Int?
  date_time_modification       DateTime?     @db.Timestamptz(6)
  users_alerts_admin_idTousers users         @relation("alerts_admin_idTousers", fields: [admin_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_alerts_admin")
  customers                    customers?    @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_alerts_customer")
  fields                       fields?       @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_alerts_field")
  reservations                 reservations? @relation(fields: [reservation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_alerts_reservation")
  users_alerts_user_idTousers  users?        @relation("alerts_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_alerts_user")

  @@index([admin_id], map: "idx_alerts_admin_id")
  @@index([date_time_registration], map: "idx_alerts_created_at")
  @@index([status], map: "idx_alerts_status")
  @@index([type], map: "idx_alerts_type")
}

model badge_tiers {
  id                     Int       @id @default(autoincrement())
  badge_id               Int
  tier                   String    @db.VarChar(20)
  icon                   String?   @db.VarChar(255)
  label                  String?   @db.VarChar(100)
  required_value         Int
  reward_hours           Decimal?  @default(0.00) @db.Decimal(10, 2)
  color                  String?   @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  badges                 badges    @relation(fields: [badge_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_badge_tiers_badge")

  @@unique([badge_id, tier], map: "uk_badge_tiers")
}

model badges {
  id                     Int               @id @default(autoincrement())
  name                   String            @unique @db.VarChar(255)
  icon                   String?           @db.VarChar(255)
  description            String?
  criteria_type          String            @db.VarChar(50)
  is_active              Boolean?          @default(true)
  status                 String?           @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime?         @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?         @db.Timestamptz(6)
  criteria_id            Int?
  badge_tiers            badge_tiers[]
  badge_criteria         badge_criteria?   @relation(fields: [criteria_id], references: [id], onUpdate: NoAction, map: "fk_badges_criteria")
  customer_badges        customer_badges[]

  @@index([criteria_id], map: "idx_badges_criteria_id")
}

model blacklist {
  id                     Int       @id @default(autoincrement())
  phone_number           String    @unique @db.VarChar(20)
  customer_name          String    @db.VarChar(255)
  reason                 String
  blocked_by             Int
  blocked_at             DateTime? @default(now()) @db.Timestamptz(6)
  blocked_until          DateTime? @db.Timestamptz(6)
  reservations_missed    Int?      @default(0)
  status                 String?   @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  users                  users     @relation(fields: [blocked_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_blacklist_blocked_by")

  @@index([blocked_by], map: "idx_blacklist_blocked_by")
  @@index([phone_number], map: "idx_blacklist_phone_number")
}

model booking_alert_rules {
  id                     Int       @id @default(autoincrement())
  name                   String    @db.VarChar(255)
  sport_types            Json?
  time_ranges            Json?
  days                   Json?
  enabled                Boolean?  @default(true)
  notify_in_app          Boolean?  @default(true)
  notify_whatsapp        Boolean?  @default(false)
  notify_email           Boolean?  @default(false)
  created_by             Int
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  users                  users     @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_booking_alert_rules_created_by")
}

model coupon_fields {
  id                     Int       @id @default(autoincrement())
  coupon_id              Int
  field_id               Int
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  coupons                coupons   @relation(fields: [coupon_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_coupon_fields_coupon")
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_coupon_fields_field")

  @@unique([coupon_id, field_id], map: "uk_coupon_fields")
}

model coupon_usage {
  id                     Int          @id @default(autoincrement())
  coupon_id              Int
  user_id                Int?
  customer_id            Int?
  reservation_id         Int
  used_at                DateTime?    @default(now()) @db.Timestamptz(6)
  user_id_registration   Int?
  date_time_registration DateTime?    @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?    @db.Timestamptz(6)
  coupons                coupons      @relation(fields: [coupon_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_coupon_usage_coupon")
  customers              customers?   @relation(fields: [customer_id], references: [id], onUpdate: NoAction, map: "fk_coupon_usage_customer")
  reservations           reservations @relation(fields: [reservation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_coupon_usage_reservation")
  users                  users?       @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_coupon_usage_user")
}

model coupons {
  id                     Int             @id @default(autoincrement())
  code                   String          @unique @db.VarChar(50)
  name                   String          @db.VarChar(255)
  description            String?
  type                   String          @db.VarChar(20)
  value                  Decimal         @db.Decimal(10, 2)
  is_active              Boolean?        @default(true)
  usage_limit            Int?
  used_count             Int?            @default(0)
  valid_from             DateTime        @db.Date
  valid_until            DateTime        @db.Date
  min_purchase           Decimal?        @default(0.00) @db.Decimal(10, 2)
  applicable_fields      Json?
  created_by             Int
  status                 String?         @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime?       @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?       @db.Timestamptz(6)
  coupon_fields          coupon_fields[]
  coupon_usage           coupon_usage[]
  users                  users           @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_coupons_created_by")
  reservations           reservations[]

  @@index([code], map: "idx_coupons_code")
  @@index([is_active], map: "idx_coupons_is_active")
  @@index([valid_from], map: "idx_coupons_valid_from")
  @@index([valid_until], map: "idx_coupons_valid_until")
}

model customer_badges {
  id                     Int       @id @default(autoincrement())
  customer_id            Int
  badge_id               Int
  tier                   String    @db.VarChar(20)
  unlocked_at            DateTime? @default(now()) @db.Timestamptz(6)
  auto_assigned          Boolean?  @default(false)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  badges                 badges    @relation(fields: [badge_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_customer_badges_badge")
  customers              customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_customer_badges_customer")

  @@unique([customer_id, badge_id, tier], map: "uk_customer_badges")
}

model customer_promotion_history {
  id                     Int       @id @default(autoincrement())
  customer_id            Int
  type                   String    @db.VarChar(20)
  hours_redeemed         Decimal?  @default(0.00) @db.Decimal(10, 2)
  hours_earned           Decimal?  @default(0.00) @db.Decimal(10, 2)
  remaining_hours        Decimal?  @default(0.00) @db.Decimal(10, 2)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  customers              customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_customer_promotion_history_customer")
}

model customers {
  id                                Int                              @id @default(autoincrement())
  user_id                           Int?
  phone_number                      String                           @unique @db.VarChar(20)
  name                              String                           @db.VarChar(255)
  email                             String?                          @db.VarChar(255)
  created_by                        Int
  total_reservations                Int?                             @default(0)
  total_hours                       Decimal?                         @default(0.00) @db.Decimal(10, 2)
  total_spent                       Decimal?                         @default(0.00) @db.Decimal(10, 2)
  earned_free_hours                 Decimal?                         @default(0.00) @db.Decimal(10, 2)
  used_free_hours                   Decimal?                         @default(0.00) @db.Decimal(10, 2)
  available_free_hours              Decimal?                         @default(0.00) @db.Decimal(10, 2)
  last_reservation                  DateTime?                        @db.Timestamptz(6)
  is_vip                            Boolean?                         @default(false)
  notes                             String?
  status                            String?                          @default("active") @db.VarChar(20)
  user_id_registration              Int?
  date_time_registration            DateTime?                        @default(now()) @db.Timestamptz(6)
  user_id_modification              Int?
  date_time_modification            DateTime?                        @db.Timestamptz(6)
  accumulated_hours                 Decimal?                         @default(0.00) @db.Decimal(10, 2)
  alerts                            alerts[]
  coupon_usage                      coupon_usage[]
  customer_badges                   customer_badges[]
  customer_promotion_history        customer_promotion_history[]
  customer_promotion_redemptions    customer_promotion_redemptions[]
  users_customers_created_byTousers users                            @relation("customers_created_byTousers", fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_customers_created_by")
  users_customers_user_idTousers    users?                           @relation("customers_user_idTousers", fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_customers_user")
  refunds                           refunds[]
  reservations                      reservations[]
  reviews                           reviews[]

  @@index([created_by], map: "idx_customers_created_by")
  @@index([is_vip], map: "idx_customers_is_vip")
  @@index([phone_number], map: "idx_customers_phone_number")
}

model departments {
  id                     Int         @id @default(autoincrement())
  code                   String      @unique @db.VarChar(2)
  name                   String      @db.VarChar(100)
  user_id_registration   Int?
  date_time_registration DateTime?   @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?   @db.Timestamptz(6)
  districts              districts[]
  provinces              provinces[]
}

model districts {
  id                     Int         @id @default(autoincrement())
  code                   String      @unique @db.VarChar(6)
  name                   String      @db.VarChar(100)
  province_id            Int
  department_id          Int
  user_id_registration   Int?
  date_time_registration DateTime?   @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?   @db.Timestamptz(6)
  departments            departments @relation(fields: [department_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_districts_department")
  provinces              provinces   @relation(fields: [province_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_districts_province")
  fields                 fields[]

  @@index([code], map: "idx_districts_code")
  @@index([province_id], map: "idx_districts_province_id")
}

model field_amenities {
  id                     Int       @id @default(autoincrement())
  field_id               Int
  amenity                String    @db.VarChar(255)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_amenities_field")
}

model field_cancellation_policies {
  id                     Int       @id @default(autoincrement())
  field_id               Int       @unique
  allow_cancellation     Boolean?  @default(true)
  hours_before_event     Int?      @default(24)
  refund_percentage      Decimal?  @default(100.00) @db.Decimal(5, 2)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_cancellation_policies_field")
}

model field_dimensions {
  id                     Int       @id @default(autoincrement())
  field_id               Int       @unique
  length                 String?   @db.VarChar(50)
  width                  String?   @db.VarChar(50)
  area                   String?   @db.VarChar(50)
  goal_size              String?   @db.VarChar(50)
  court_type             String?   @db.VarChar(50)
  surface_type           String?   @db.VarChar(30)
  basket_height          String?   @db.VarChar(20)
  net_height             String?   @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_dimensions_field")
}

model field_equipment {
  id                     Int       @id @default(autoincrement())
  field_id               Int       @unique
  has_jersey_rental      Boolean?  @default(false)
  jersey_price           Decimal?  @db.Decimal(10, 2)
  has_ball_rental        Boolean?  @default(false)
  ball_rental_price      Decimal?  @db.Decimal(10, 2)
  has_scoreboard         Boolean?  @default(false)
  has_nets               Boolean?  @default(true)
  has_goals              Boolean?  @default(true)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  has_cone_rental        Boolean?  @default(false)
  cone_price             Decimal?  @db.Decimal(10, 2)
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_equipment_field")
}

model field_images {
  id                     Int       @id @default(autoincrement())
  field_id               Int
  image_url              String
  category               String?   @db.VarChar(50)
  is_primary             Boolean?  @default(false)
  order_index            Int?      @default(0)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_images_field")
}

model field_maintenance_schedules {
  id                     Int       @id @default(autoincrement())
  field_id               Int
  start_date             DateTime  @db.Date
  end_date               DateTime  @db.Date
  start_time             DateTime? @db.Time(6)
  end_time               DateTime? @db.Time(6)
  reason                 String?
  is_recurring           Boolean?  @default(false)
  recurrence_pattern     String?   @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_maintenance_field")
}

model field_rules {
  id                     Int       @id @default(autoincrement())
  field_id               Int
  rule                   String
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_rules_field")
}

model field_schedules {
  id                     Int       @id @default(autoincrement())
  field_id               Int
  day_of_week            String    @db.VarChar(10)
  is_open                Boolean?  @default(true)
  open_time              DateTime? @db.Time(6)
  close_time             DateTime? @db.Time(6)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_schedules_field")
}

model field_special_pricing {
  id                     Int       @id @default(autoincrement())
  field_id               Int
  name                   String    @db.VarChar(255)
  description            String?
  price                  Decimal   @db.Decimal(10, 2)
  discount_type          String    @default("percentage") @db.VarChar(20)
  time_ranges            Json?
  days                   Json?
  is_active              Boolean?  @default(true)
  status                 String?   @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_special_pricing_field")
}

model field_sports {
  id                     Int         @id @default(autoincrement())
  field_id               Int
  sport_id               Int
  user_id_registration   Int?
  date_time_registration DateTime?   @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime?   @db.Timestamptz(6)
  fields                 fields      @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_sports_field")
  sport_types            sport_types @relation(fields: [sport_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_sports_sport")

  @@unique([field_id, sport_id], map: "uk_field_sports")
}

model field_videos {
  id                     Int       @id @default(autoincrement())
  field_id               Int
  video_url              String
  title                  String?   @db.VarChar(255)
  description            String?
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_videos_field")
}

model fields {
  id                              Int                           @id @default(autoincrement())
  admin_id                        Int
  name                            String                        @db.VarChar(255)
  location                        String?
  departamento                    String?                       @db.VarChar(100)
  provincia                       String?                       @db.VarChar(100)
  distrito                        String?                       @db.VarChar(100)
  district_id                     Int?
  address                         String?
  phone                           String?                       @db.VarChar(20)
  latitude                        Decimal?                      @db.Decimal(10, 8)
  longitude                       Decimal?                      @db.Decimal(11, 8)
  price_per_hour                  Decimal                       @db.Decimal(10, 2)
  status                          String?                       @default("available") @db.VarChar(20)
  approval_status                 String?                       @default("pending") @db.VarChar(20)
  field_type                      String?                       @db.VarChar(50)
  sport_type                      Int?
  capacity                        Int?
  requires_advance_payment        Boolean?                      @default(false)
  is_active                       Boolean?                      @default(true)
  is_multi_sport                  Boolean?                      @default(false)
  rating                          Decimal?                      @default(0.00) @db.Decimal(3, 2)
  total_reviews                   Int?                          @default(0)
  approved_by                     Int?
  approved_at                     DateTime?                     @db.Timestamptz(6)
  rejected_by                     Int?
  rejected_at                     DateTime?                     @db.Timestamptz(6)
  rejection_reason                String?
  created_by                      Int?
  user_id_registration            Int?
  date_time_registration          DateTime?                     @default(now()) @db.Timestamptz(6)
  user_id_modification            Int?
  date_time_modification          DateTime?                     @db.Timestamptz(6)
  advance_payment_amount          Decimal?                      @default(0.00) @db.Decimal(10, 2)
  alerts                          alerts[]
  coupon_fields                   coupon_fields[]
  field_amenities                 field_amenities[]
  field_cancellation_policies     field_cancellation_policies?
  field_dimensions                field_dimensions?
  field_equipment                 field_equipment?
  field_images                    field_images[]
  field_maintenance_schedules     field_maintenance_schedules[]
  field_payment_methods           field_payment_methods[]
  field_rules                     field_rules[]
  field_schedules                 field_schedules[]
  field_special_pricing           field_special_pricing[]
  field_sports                    field_sports[]
  field_videos                    field_videos[]
