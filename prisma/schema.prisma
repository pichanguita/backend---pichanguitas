  alerts_alerts_admin_idTousers                              alerts[]                @relation("alerts_admin_idTousers")
  alerts_alerts_user_idTousers                               alerts[]                @relation("alerts_user_idTousers")
  blacklist                                                  blacklist[]
  booking_alert_rules                                        booking_alert_rules[]
  coupon_usage                                               coupon_usage[]
  coupons                                                    coupons[]
  customers_customers_created_byTousers                      customers[]             @relation("customers_created_byTousers")
  customers_customers_user_idTousers                         customers[]             @relation("customers_user_idTousers")
  fields_fields_admin_idTousers                              fields[]                @relation("fields_admin_idTousers")
  fields_fields_approved_byTousers                           fields[]                @relation("fields_approved_byTousers")
  fields_fields_created_byTousers                            fields[]                @relation("fields_created_byTousers")
  fields_fields_rejected_byTousers                           fields[]                @relation("fields_rejected_byTousers")
  monthly_payments                                           monthly_payments[]
  password_reset_tokens                                      password_reset_tokens[]
  payment_configs                                            payment_configs[]
  payments_payments_admin_idTousers                          payments[]              @relation("payments_admin_idTousers")
  payments_payments_registered_byTousers                     payments[]              @relation("payments_registered_byTousers")
  promotion_rules                                            promotion_rules[]
  refunds                                                    refunds[]
  registration_requests                                      registration_requests[]
  reservations_reservations_approved_byTousers               reservations[]          @relation("reservations_approved_byTousers")
  reservations_reservations_rejected_byTousers               reservations[]          @relation("reservations_rejected_byTousers")
  user_managed_fields_user_managed_fields_assigned_byTousers user_managed_fields[]   @relation("user_managed_fields_assigned_byTousers")
  user_managed_fields_user_managed_fields_user_idTousers     user_managed_fields[]   @relation("user_managed_fields_user_idTousers")
  user_permissions                                           user_permissions[]
  users                                                      users?                  @relation("usersTousers", fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_users_created_by")
  other_users                                                users[]                 @relation("usersTousers")
  roles                                                      roles                   @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_users_role")

  @@index([email], map: "idx_users_email")
  @@index([email, phone], map: "idx_users_email_phone")
  @@index([is_active], map: "idx_users_is_active")
  @@index([phone], map: "idx_users_phone")
  @@index([role_id], map: "idx_users_role_id")
  @@index([username], map: "idx_users_username")
}

model field_payment_methods {
  id                     Int       @id @default(autoincrement())
  field_id               Int
  method_type            String    @db.VarChar(20)
  is_enabled             Boolean?  @default(true)
  account_number         String?   @db.VarChar(50)
  account_holder         String?   @db.VarChar(255)
  phone_number           String?   @db.VarChar(20)
  qr_image_url           String?
  bank_name              String?   @db.VarChar(100)
  cci_number             String?   @db.VarChar(30)
  instructions           String?
  order_index            Int?      @default(0)
  status                 String?   @default("active") @db.VarChar(20)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  fields                 fields    @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_field_payment_methods_field")

  @@unique([field_id, method_type], map: "uk_field_payment_methods")
  @@index([field_id], map: "idx_field_payment_methods_field_id")
}

model badge_criteria {
  id                     Int       @id @default(autoincrement())
  code                   String    @unique @db.VarChar(50)
  name                   String    @db.VarChar(255)
  description            String?
  calculation_table      String    @db.VarChar(100)
  calculation_field      String    @db.VarChar(100)
  calculation_type       String    @default("count") @db.VarChar(20)
  filter_conditions      Json?
  is_active              Boolean?  @default(true)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)
  badges                 badges[]

  @@index([code], map: "idx_badge_criteria_code")
}

model customer_promotion_redemptions {
  id                     Int             @id @default(autoincrement())
  customer_id            Int
  promotion_rule_id      Int
  hours_earned           Decimal         @db.Decimal(10, 2)
  redeemed_at            DateTime?       @default(now()) @db.Timestamptz(6)
  user_id_registration   Int?
  date_time_registration DateTime?       @default(now()) @db.Timestamptz(6)
  customers              customers       @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  promotion_rules        promotion_rules @relation(fields: [promotion_rule_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([customer_id, promotion_rule_id], map: "customer_promotion_redemption_customer_id_promotion_rule_id_key")
  @@index([customer_id], map: "idx_cpr_customer")
  @@index([promotion_rule_id], map: "idx_cpr_promotion")
}

model platform_payment_methods {
  id                     Int       @id @default(autoincrement())
  method_type            String    @db.VarChar(30)
  name                   String    @db.VarChar(100)
  bank_name              String?   @db.VarChar(100)
  account_number         String?   @db.VarChar(50)
  account_holder         String?   @db.VarChar(255)
  cci_number             String?   @db.VarChar(30)
  phone_number           String?   @db.VarChar(20)
  qr_image_url           String?   @db.VarChar(500)
  instructions           String?
  is_active              Boolean?  @default(true)
  order_index            Int?      @default(0)
  user_id_registration   Int?
  date_time_registration DateTime? @default(now()) @db.Timestamptz(6)
  user_id_modification   Int?
  date_time_modification DateTime? @db.Timestamptz(6)

  @@index([is_active], map: "idx_platform_payment_methods_active")
  @@index([method_type], map: "idx_platform_payment_methods_type")
}


model gamification_config {
  id                     Int       @id @default(autoincrement())
  config_key             String    @unique @db.VarChar(100)
  config_value           String?   @db.VarChar(500)
  description            String?   @db.VarChar(255)
  user_id_modification   Int?
  date_time_modification DateTime? @default(now()) @db.Timestamptz(6)
}

model password_reset_tokens {
  id         Int       @id @default(autoincrement())
  user_id    Int
  token_hash String    @db.VarChar(255)
  expires_at DateTime  @db.Timestamptz(6)
  used       Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token_hash], map: "idx_prt_token_hash")
  @@index([user_id], map: "idx_prt_user_id")
}
