# ==================================================
# CONFIGURACIÓN BACKEND - PICHANGUITAS
# ==================================================
# Este archivo sirve como plantilla para configurar
# las variables de entorno del backend.
# Copiar este archivo como .env y configurar valores.
# ==================================================

# ==================================================
# SERVIDOR
# ==================================================
# Puerto en el que correrá el servidor backend
# Railway asigna automáticamente el puerto mediante la variable PORT
# En local, usar el puerto deseado (ej: 4009)
PORT=4009

# Entorno de ejecución (development, production)
# Railway configura esto automáticamente como 'production'
# En local, usar 'development'
NODE_ENV=development

# ==================================================
# BASE DE DATOS - POSTGRESQL
# ==================================================
# URL de conexión a PostgreSQL
#
# FORMATO:
# postgresql://[usuario]:[contraseña]@[host]:[puerto]/[nombre_bd]
#
# EJEMPLOS:
# - Local: postgresql://postgres:password@localhost:5432/db_pichanguitas
# - Railway: postgresql://postgres:xxx@xxx.proxy.rlwy.net:xxxxx/railway
#
# Railway proporciona esta variable automáticamente cuando
# vinculas un servicio de PostgreSQL a tu proyecto
DATABASE_URL="postgresql://postgres:password@localhost:5432/db_pichanguitas"

# ==================================================
# SEGURIDAD - JWT
# ==================================================
# Clave secreta para firmar tokens JWT
# IMPORTANTE: Usar una clave segura y única en producción
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_secreto_jwt_super_seguro_cambiar_en_produccion

# ==================================================
# CORS (Opcional)
# ==================================================
# Origen permitido para CORS
# En desarrollo local, el frontend corre en http://localhost:3009
# En Railway, será la URL de tu frontend desplegado
# CORS_ORIGIN=http://localhost:3009

# ==================================================
# TIMEZONE (IMPORTANTE PARA RAILWAY)
# ==================================================
# Zona horaria del servidor
# IMPORTANTE: En Railway, DEBES configurar esta variable para
# que las fechas y CRON jobs funcionen correctamente en hora de Perú.
# En local (Windows/Linux), el sistema usa su propia zona horaria.
TZ=America/Lima

# ==================================================
# EMAIL - RESEND (Recuperacion de contrasena)
# ==================================================
# Servicio de email via API HTTPS (compatible con Railway)
# Crear cuenta gratuita en: https://resend.com
# Obtener API Key en: Dashboard > API Keys
#
# RESEND_FROM requiere dominio verificado en Resend.
# Para testing usar: onboarding@resend.dev
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM=Pichanguitas <onboarding@resend.dev>

# URL del frontend (para links en emails)
# En desarrollo local: http://localhost:3009
# En produccion: tu URL de Railway frontend
FRONTEND_URL=http://localhost:3009

# ==================================================
# WASABI CLOUD STORAGE (S3-compatible)
# ==================================================
# Credenciales de acceso a Wasabi
# Obtener desde: https://console.wasabisys.com → Access Keys
WASABI_ACCESS_KEY=tu_access_key
WASABI_SECRET_KEY=tu_secret_key

# Nombre del bucket (se crea automaticamente si no existe)
WASABI_BUCKET=pichanguitas-uploads

# Region de Wasabi (us-east-1, us-east-2, us-west-1, eu-central-1, ap-northeast-1)
WASABI_REGION=us-east-1

# Endpoint de Wasabi (se genera automaticamente desde la region si no se especifica)
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com

# ==================================================
# CONFIGURACION ADICIONAL
# ==================================================
# Limite de payload (para imagenes base64)
# PAYLOAD_LIMIT=50mb

# Timeout de conexión a la base de datos (ms)
# DB_CONNECTION_TIMEOUT=5000

# Número máximo de conexiones en el pool
# DB_POOL_MAX=10

# Número mínimo de conexiones en el pool
# DB_POOL_MIN=2
